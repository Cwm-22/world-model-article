# ============================================================
# 世界模型论文监控智能体 - 环境变量示例
# 使用前复制为 .env 并填入真实值： cp .env.example .env
# ============================================================

# 【必填】智谱 GLM API Key（OpenAI 兼容接口）
GLM_API_KEY=your_glm_api_key_here

# 【可选】GLM 接口配置（默认值通常无需修改）
GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
GLM_MODEL=glm-5.2

# ============================================================
# 检索配置
# ============================================================

# 【可选】arXiv 检索分类（逗号分隔）
ARXIV_CATEGORIES=cs.CV,cs.AI,cs.RO,cs.LG

# 【可选】检索关键词（逗号分隔，任一命中即纳入候选）
# 默认已放宽到 26 个，覆盖世界模型大领域：
#   世界模型族 / 生成式 3D / 视频未来预测 / 具身机器人仿真 / 前向动力学 等
# 不需要逐项配置；如需自定义，可只列出你关心的子方向关键词。
SEARCH_KEYWORDS=world model,world models,world simulator,world simulation,3D scene generation,scene synthesis,generative 3D world,explorable world,3D world modeling,scene completion,video world model,video prediction,future prediction,action-conditioned video,dreamer,embodied world simulation,embodied world model,robot world model,interactive environment,physics-based simulation,robot learning simulator,forward dynamics,latent dynamics,planet model,recurrent state space model,action-conditioned prediction

# 【可选】仅保留此日期之后提交的论文（YYYYMMDD）
SINCE_DATE=20260101

# 【可选】每日拉取论文数上限（聚合后截断）
MAX_PAPERS_PER_DAY=20

# 【可选】选取 Top 几篇生成推文
TOP_K=3

# ============================================================
# 多数据源开关（默认全部启用；置 0 关闭）
# ============================================================

# arXiv 官方 API
ENABLE_ARXIV=1
# HuggingFace Daily Papers（人工策展 + upvotes + githubRepo）
ENABLE_HF_DAILY=1
# OpenReview（ICLR/NeurIPS/COLM 等顶会稿件；本地受限网络可能 403）
ENABLE_OPENREVIEW=1
# Semantic Scholar（关键词检索 + 按 arXiv id 富化 venue/citationCount）
ENABLE_SEMANTIC_SCHOLAR=1

# 【可选】各源参数
# HuggingFace Daily 回看天数
HF_LOOKBACK_DAYS=14
# OpenReview 仅保留此年之后的稿件
OPENREVIEW_SINCE_YEAR=2024
# Semantic Scholar 关键词检索下限年份
SEMANTIC_SCHOLAR_SINCE_YEAR=2024

# 【可选】Semantic Scholar API Key（可选，用于提升限流配额）
# 申请入口： https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# 推送配置（生成 PDF 后发送）
# 优先级：邮件 > 企业微信群机器人 > wxauto 控制 PC 微信
# ============================================================

# 【推送 - 邮件（推荐）】通过 SMTP 把 PDF 作为附件发到你邮箱。
# 手机邮箱 App 收到推送后即可打开 PDF；电脑关机也能收（GitHub Actions 发送）。
# QQ 邮箱：在「设置 -> 账户 -> 开启 SMTP」后生成授权码填到 SMTP_PASS。
# 163 邮箱：在「设置 -> POP3/SMTP/IMAP -> 开启 SMTP」后生成客户端授权码。
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_auth_code
SMTP_FROM=your_email@qq.com
SMTP_TO=your_email@qq.com

# 【推送 - 企业微信群机器人（可选备选）】
# 企业微信群 -> 右上角 ... -> 添加群机器人 -> 自定义机器人 -> 复制 Webhook URL
# 这里只填 URL 末尾 key= 之后的部分（或整条 URL 亦可）。
WECOM_BOT_KEY=

# 【推送 - wxauto 控制 PC 微信（本地备用，需电脑登录微信）】
WX_TARGET=文件传输助手